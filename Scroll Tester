# ---------------------------------------------------------------------------
# Fighter base class
# ATK and AC computed here where all stats are in scope
# ---------------------------------------------------------------------------

Fighter (SDNPC) {
    Race   @ Race
    Class! = "Fighter"

    Weapon @ SDFighterWeapon
    Armor  @ SDFighterArmor

    ArmorValue! ~ <%
        {% set DexMod = round((BaseDexterity - 10.5) / 2, 0) %}
        {% set Shield = 0 %}
        {% if existsIn(Armor, "ShieldBonus") %}{% set Shield = Armor.ShieldBonus %}{% endif %}
        {% if Armor.UsesDex %}
            {{Armor.BaseAC + DexMod + Shield}} ({{Armor.Name}})
        {% else %}
            {{Armor.BaseAC + Shield}} ({{Armor.Name}})
        {% endif %}
    %>

    Talent1! @ FighterTalent
    Talent2! @ FighterTalent

    AttackTalentBonus! ~ <%
        {% set B = 0 %}
        {% if Talent1.Description == "+1 to melee and ranged attacks" %}{% set B = B + 1 %}{% endif %}
        {% if Race.class == "RaceHuman" and Talent2.Description == "+1 to melee and ranged attacks" %}{% set B = B + 1 %}{% endif %}
        {{B}}
    %>

    ATK! ~ <%
        {% set StrMod = round((BaseStrength - 10.5) / 2, 0) %}
        {% set Total = StrMod + AttackTalentBonus %}
        {{Weapon.WeaponName}} {%if Total >= 0%}+{{Total}}{%else%}{{Total}}{%endif%} ({{Weapon.DamageRoll}})
    %>

    ClassAbility! ~ <%
        Weapon Mastery, Grit, Hauler.
        Talents: {{Talent1.Description}}
        {%if Race.class == "RaceHuman"%}; {{Talent2.Description}}{%endif%}
    %>

    | SDNPC
}

