        {% set DexBonus = 0 %}
        {% set ConBonus = 0 %}
        {% set IntBonus = 0 %}
        {% set WisBonus = 0 %}
        {% set ChaBonus = 0 %}
        {% if exists("Talent1") and Talent1.Description == "+2 to STR" %}{% set StrBonus = StrBonus + 2 %}{% endif %}
        {% if exists("Talent1") and Talent1.Description == "+2 to DEX" %}{% set DexBonus = DexBonus + 2 %}{% endif %}
        {% if exists("Talent1") and Talent1.Description == "+2 to CON" %}{% set ConBonus = ConBonus + 2 %}{% endif %}
        {% if exists("Talent1") and Talent1.Description == "+2 to INT" %}{% set IntBonus = IntBonus + 2 %}{% endif %}
        {% if exists("Talent1") and Talent1.Description == "+2 to WIS" %}{% set WisBonus = WisBonus + 2 %}{% endif %}
        {% if exists("Talent1") and Talent1.Description == "+2 to CHA" %}{% set ChaBonus = ChaBonus + 2 %}{% endif %}
        {% if exists("Talent2") and Race.class == "RaceHuman" and Talent2.Description == "+2 to STR" %}{% set StrBonus = StrBonus + 2 %}{% endif %}
        {% if exists("Talent2") and Race.class == "RaceHuman" and Talent2.Description == "+2 to DEX" %}{% set DexBonus = DexBonus + 2 %}{% endif %}
        {% if exists("Talent2") and Race.class == "RaceHuman" and Talent2.Description == "+2 to CON" %}{% set ConBonus = ConBonus + 2 %}{% endif %}
        {% if exists("Talent2") and Race.class == "RaceHuman" and Talent2.Description == "+2 to INT" %}{% set IntBonus = IntBonus + 2 %}{% endif %}
        {% if exists("Talent2") and Race.class == "RaceHuman" and Talent2.Description == "+2 to WIS" %}{% set WisBonus = WisBonus + 2 %}{% endif %}
        {% if exists("Talent2") and Race.class == "RaceHuman" and Talent2.Description == "+2 to CHA" %}{% set ChaBonus = ChaBonus + 2 %}{% endif %}
        {% if exists("Talent3") and Talent3.Description == "+2 to STR" %}{% set StrBonus = StrBonus + 2 %}{% endif %}
        {% if exists("Talent3") and Talent3.Description == "+2 to DEX" %}{% set DexBonus = DexBonus + 2 %}{% endif %}
        {% if exists("Talent3") and Talent3.Description == "+2 to CON" %}{% set ConBonus = ConBonus + 2 %}{% endif %}
        {% if exists("Talent3") and Talent3.Description == "+2 to INT" %}{% set IntBonus = IntBonus + 2 %}{% endif %}
        {% if exists("Talent3") and Talent3.Description == "+2 to WIS" %}{% set WisBonus = WisBonus + 2 %}{% endif %}
        {% if exists("Talent3") and Talent3.Description == "+2 to CHA" %}{% set ChaBonus = ChaBonus + 2 %}{% endif %}
        {% if exists("Talent4") and Talent4.Description == "+2 to STR" %}{% set StrBonus = StrBonus + 2 %}{% endif %}
        {% if exists("Talent4") and Talent4.Description == "+2 to DEX" %}{% set DexBonus = DexBonus + 2 %}{% endif %}
        {% if exists("Talent4") and Talent4.Description == "+2 to CON" %}{% set ConBonus = ConBonus + 2 %}{% endif %}
        {% if exists("Talent4") and Talent4.Description == "+2 to INT" %}{% set IntBonus = IntBonus + 2 %}{% endif %}
        {% if exists("Talent4") and Talent4.Description == "+2 to WIS" %}{% set WisBonus = WisBonus + 2 %}{% endif %}
        {% if exists("Talent4") and Talent4.Description == "+2 to CHA" %}{% set ChaBonus = ChaBonus + 2 %}{% endif %}
        {% if exists("Talent5") and Talent5.Description == "+2 to STR" %}{% set StrBonus = StrBonus + 2 %}{% endif %}
        {% if exists("Talent5") and Talent5.Description == "+2 to DEX" %}{% set DexBonus = DexBonus + 2 %}{% endif %}
        {% if exists("Talent5") and Talent5.Description == "+2 to CON" %}{% set ConBonus = ConBonus + 2 %}{% endif %}
        {% if exists("Talent5") and Talent5.Description == "+2 to INT" %}{% set IntBonus = IntBonus + 2 %}{% endif %}
        {% if exists("Talent5") and Talent5.Description == "+2 to WIS" %}{% set WisBonus = WisBonus + 2 %}{% endif %}
        {% if exists("Talent5") and Talent5.Description == "+2 to CHA" %}{% set ChaBonus = ChaBonus + 2 %}{% endif %}
        {% if exists("Talent6") and Talent6.Description == "+2 to STR" %}{% set StrBonus = StrBonus + 2 %}{% endif %}
        {% if exists("Talent6") and Talent6.Description == "+2 to DEX" %}{% set DexBonus = DexBonus + 2 %}{% endif %}
        {% if exists("Talent6") and Talent6.Description == "+2 to CON" %}{% set ConBonus = ConBonus + 2 %}{% endif %}
        {% if exists("Talent6") and Talent6.Description == "+2 to INT" %}{% set IntBonus = IntBonus + 2 %}{% endif %}
        {% if exists("Talent6") and Talent6.Description == "+2 to WIS" %}{% set WisBonus = WisBonus + 2 %}{% endif %}
        {% if exists("Talent6") and Talent6.Description == "+2 to CHA" %}{% set ChaBonus = ChaBonus + 2 %}{% endif %}
        {% set FinalStr = BaseStrength + StrBonus %}
        {% set FinalDex = BaseDexterity + DexBonus %}
        {% set FinalCon = BaseConstitution + ConBonus %}
        {% set FinalInt = BaseIntelligence + IntBonus %}
        {% set FinalWis = BaseWisdom + WisBonus %}
        {% set FinalCha = BaseCharisma + ChaBonus %}
        {% set FinalIntMod = round((FinalInt - 10.5) / 2, 0) %}
        {% set FinalWisMod = round((FinalWis - 10.5) / 2, 0) %}
        {% set FinalChaMod = round((FinalCha - 10.5) / 2, 0) %}
        {% set FinalStrMod = round((FinalStr - 10.5) / 2, 0) %}
        {% set FinalDexMod = round((FinalDex - 10.5) / 2, 0) %}
        {% set FinalConMod = round((FinalCon - 10.5) / 2, 0) %}
