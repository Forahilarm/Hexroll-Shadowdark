FighterTalent {
    Description! @ [
        *     Weapon Mastery with one additional weapon type
        *(x4) +1 to melee and ranged attacks
        *(x3) +2 to Strength, Dexterity, or Constitution
        *(x2) +1 AC from chosen armor type
        *     Choose a talent or +2 points to distribute to stats
    ]
}

Fighter (SDNPC) {
    Race   @ Race
    Class! = "Fighter"

    Weapon @ SDFighterWeapon
    Armor  @ SDFighterArmor

    CalculatedHP! ~ <%
        {% set ConMod = round((BaseConstitution - 10.5) / 2, 0) %}
        {% set DBonus = 0 %}
        {% if Race.class == "RaceDwarf" %}{% set DBonus = 2 %}{% endif %}
        {{max(8 + HPDice + ConMod + DBonus, 1)}}
    %>

    ArmorValue! ~ <%
        {% set DexMod = round((BaseDexterity - 10.5) / 2, 0) %}
        {% set ShieldBonus = 0 %}
        {% if existsIn(Armor, "ShieldBonus") %}{% set ShieldBonus = Armor.ShieldBonus %}{% endif %}
        {% if Armor.UsesDex %}
            {{Armor.BaseAC + DexMod + ShieldBonus}} ({{Armor.Name}})
        {% else %}
            {{Armor.BaseAC + ShieldBonus}} ({{Armor.Name}})
        {% endif %}
    %>

    Talent1! @ FighterTalent
    Talent2! @ FighterTalent

    AttackTalentBonus! ~ <%
        {% set Bonus = 0 %}
        {% if Talent1.Description == "+1 to melee and ranged attacks" %}{% set Bonus = Bonus + 1 %}{% endif %}
        {% if Race.class == "RaceHuman" and Talent2.Description == "+1 to melee and ranged attacks" %}{% set Bonus = Bonus + 1 %}{% endif %}
        {{Bonus}}
    %>

    ATK! ~ <%
        {% set StrMod = round((BaseStrength - 10.5) / 2, 0) %}
        {% set Total = StrMod + AttackTalentBonus %}
        {{Weapon.WeaponName}} {%if Total >= 0%}+{{Total}}{%else%}{{Total}}{%endif%} ({{Weapon.DamageRoll}})
    %>

    ClassAbility! ~ <%
        Weapon Mastery, Grit, Hauler.
        Talents: {{Talent1.Description}}
        {%if Race.class == "RaceHuman"%}; {{Talent2.Description}}{%endif%}
    %>

    | SDNPC
}


