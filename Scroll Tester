# Shadowdark Fighter Test Scroll
# Paste into scroll.hexroll.app in 5E MODE and hit Play

+ O5E

# ---------------------------------------------------------------------------
# RACES
# ---------------------------------------------------------------------------

RaceHuman {
    Title! = "Human"
    BaseWalkingSpeed! = Near
    RacialTraits! = "Ambitious: gain one additional talent roll at 1st level"
    BaseLanguages! = "Common, one additional common language"
    Feature! @ [
        * a weathered, road-worn look
        * a collection of mismatched scars
        * an unusual signet ring
        * strikingly average features that are somehow hard to place
        * a permanent squint from too many years in the sun
    ]
}

RaceDwarf {
    Title! = "Dwarf"
    BaseWalkingSpeed! = Near
    RacialTraits! = "Stout: start with +2 HP, roll hit points per level with advantage"
    BaseLanguages! = "Common, Dwarvish"
    Feature! @ [
        * big, bulbous nose
        * short, fat fingers
        * a golden tooth
        * big red cheeks
        * chubby cheeks
    ]
}

RaceElf {
    Title! = "Elf"
    BaseWalkingSpeed! = Near
    RacialTraits! = "Farsight: +1 to ranged attack rolls or spellcasting checks"
    BaseLanguages! = "Common, Elvish, Sylvan"
    Feature! @ [
        * long, pointy ears
        * long, skinny fingers
        * a sigil tattooed on the neck
        * a nose ring
        * silky light skin
        * silky dark skin
        * a delicate angular face
        * a slender, graceful build
    ]
}

RaceHalfling {
    Title! = "Halfling"
    BaseWalkingSpeed! = Near
    RacialTraits! = "Stealthy: once per day, become invisible for 3 rounds"
    BaseLanguages! = "Common"
    Feature! @ [
        * short, chunky fingers
        * extremely large feet, even for a halfling
        * round, bulbous nose
        * chubby cheeks
        * big red cheeks
        * bushy eyebrows
        * a patterned coat
        * a vibrant coat
        * oversized suspenders
    ]
}

RaceHalfOrc {
    Title! = "Half-Orc"
    BaseWalkingSpeed! = Near
    RacialTraits! = "Mighty: +1 to melee attack and damage rolls"
    BaseLanguages! = "Common, Orcish"
    Feature! @ [
        * a strong, muscular physique
        * a deep scar on the right arm
        * a broken nose
        * a big nose-ring
        * a strong, angular jaw
        * a greenish-gray skin
        * sharp, tusk-like teeth
        * prominent brows
        * a heavy, muscular build
        * scars across the arms
        * tribal tattoos on the arms
        * a wide, flat nose
        * a broad, flat nose
    ]
}

RaceGoblin {
    Title! = "Goblin"
    BaseWalkingSpeed! = Near
    RacialTraits! = "Keen Senses: you can't be surprised"
    BaseLanguages! = "Common, Goblin"
    Feature! @ [
        * enormous bat-like ears
        * bright yellow eyes and mottled green skin
        * a wide gap-toothed grin
        * small but surprisingly nimble hands
        * a collection of shiny trinkets sewn into clothing
        * a flat, wide nose
        * sharp, beady eyes
    ]
}

Race {
    ^ [
        * RaceHuman
        * RaceDwarf
        * RaceElf
        * RaceHalfling
        * RaceHalfOrc
        * RaceGoblin
    ]
}

# ---------------------------------------------------------------------------
# NPC BASE
# ---------------------------------------------------------------------------

SDNPC (Character) {
    | Character

    Race @ Race

    Alignment @ [
        * Lawful
        * Neutral
        * Neutral
        * Neutral
        * Chaotic
    ]

    Background! @ [
        * Urchin. You grew up in the merciless streets of a large city
        * Wanted. There's a price on your head, but you have allies
        * Cult Initiate. You know blasphemous secrets and rituals
        * Thieves' Guild. You have connections, contacts, and debts
        * Banished. Your people cast you out for supposed crimes
        * Orphaned. An unusual guardian rescued and raised you
        * Wizard's Apprentice. You have a knack and eye for magic
        * Jeweler. You can easily appraise value and authenticity
        * Herbalist. You know plants, medicines, and poisons
        * Barbarian. You left the horde, but it never quite left you
        * Mercenary. You fought friend and foe alike for your coin
        * Sailor. Pirate, privateer, or merchant — the seas are yours
        * Acolyte. You're well trained in religious rites and doctrines
        * Soldier. You served as a fighter in an organized army
        * Ranger. The woods and wilds are your true home
        * Scout. You survived on stealth, observation, and speed
        * Minstrel. You've traveled far with your charm and talent
        * Scholar. You know much about ancient history and lore
        * Noble. A famous name has opened many doors for you
        * Chirurgeon. You know anatomy, surgery, and first aid
    ]

    Profession! = none

    Appearance! @ [
        * {{Gender.Feature}}, {{Feature1}} and {%if exists("AppearanceFeature")%}{{AppearanceFeature}}{% else if existsIn(Race,"Feature") %}{{Race.Feature}}{%else%}{{Feature2}}{%endif%}
        * {{Feature1}}, {{Gender.Feature}} and {%if exists("AppearanceFeature")%}{{AppearanceFeature}}{% else if existsIn(Race,"Feature") %}{{Race.Feature}}{%else%}{{Feature2}}{%endif%}
        * {{Gender.Feature}}, {{Feature1}} and {% if existsIn(Race,"Feature") %}{{Race.Feature}}{%else%}{{Feature2}}{%endif%}
        * {{Feature1}}, {{Gender.Feature}} and {% if existsIn(Race,"Feature") %}{{Race.Feature}}{%else%}{{Feature2}}{%endif%}
    ]

    $IndexRef @ IndexedEntity {
        Render = "Name"
        Details = <%A level {{Level}} {{Race.Title}} {{Class}}{{maybe2(", the ", Profession)}} {{maybe2("from ",capitalize(SettlementName))}}%>
        Anchor = &uuid
        Link = &HostingEntity
        Type = "location"
        Full = ""
        Search = "{{Full}}"
        Icon = "user"
    }

    CalculatedAC! ~ <%{{ArmorValue}}%>

    Description! ~ <%
        <strong>{{Name.Full}}</strong>, a level {{Level}} {{Race.Title}} {{Class}}.{{note_button(uuid)}}
        {{DescriptionInscript}}
        {{capitalize(Gender.PronounSubject)}} {{Gender.Possession}} {{Appearance}} (<em>{{State}}</em>).
        {{InThePocket.Details}}
        {{note_container(uuid)}}
        {{DescriptionPostscript}}
    %>

    Stats! ~ <%
        {% set StrMod = round((BaseStrength - 10.5) / 2, 0) %}
        {% set DexMod = round((BaseDexterity - 10.5) / 2, 0) %}
        {% set ConMod = round((BaseConstitution - 10.5) / 2, 0) %}
        {% set IntMod = round((BaseIntelligence - 10.5) / 2, 0) %}
        {% set WisMod = round((BaseWisdom - 10.5) / 2, 0) %}
        {% set ChaMod = round((BaseCharisma - 10.5) / 2, 0) %}
        <div id="block-{{uuid}}" class="monster-block">
        <div class="statblock">
        <hr/>
        <div class="statblock-top-row">
            <div><span class="section-label">LV:</span> {{Level}}</div>
            <div><span class="section-label">AC:</span> {{CalculatedAC}}</div>
            <div><span class="section-label">HP:</span> {{CalculatedHP}}</div>
            <div><span class="section-label">MV:</span> {{Race.BaseWalkingSpeed}}</div>
        </div>
