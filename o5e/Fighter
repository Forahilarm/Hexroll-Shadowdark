FighterLevel1 (Fighter) {
    Level! = 1
    BaseStrength     @ 5d3+3
    BaseDexterity    @ 3d6
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HitPoints! ~ <%
        {% set ConMod = round((BaseConstitution - 10.5) / 2, 0) %}
        {% set DwBonus = 0 %}{% if Race.class == "RaceDwarf" %}{% set DwBonus = 2 %}{% endif %}
        {{max(1d8 + ConMod + DwBonus, 1)}}
    %>
    | Fighter
