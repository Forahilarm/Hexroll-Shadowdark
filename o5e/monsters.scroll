# Shadowdark Monsters for Hexroll 2E
# ------------------------------------
# Full stat blocks from Shadowdark RPG (core book pp.194-265)
# NumberAppearing uses OSR logic:
#   Hex (wilderness) = larger roaming groups
#   Dungeon = smaller lairs/encounters
# Traits stored as text in Traits! field

# ---------------------------------------------------------------------------
# A
# ---------------------------------------------------------------------------

Aboleth (SDMonster) {
    Title! ~ "Aboleth"
    AC! ~ "16"
    HP! ~ "39"
    ATK! ~ "2 tentacle (near) +5 (1d8 + curse) or 1 tail +5 (3d6)"
    MV! ~ "near (swim)"
    Strength! ~ "+4"
    Dexterity! ~ "-1"
    Constitution! ~ "+3"
    Intelligence! ~ "+4"
    Wisdom! ~ "+2"
    Charisma! ~ "+2"
    Alignment! ~ "C"
    LV! = 8
    NumberAppearingHex! @ 1d3
    NumberAppearingDungeonArea! @ 1d2
    TreasureType! @ TreasureTypeCR10
    Traits! ~ "Curse: DC 15 CON or target turns into a deep one over 2d10 days. Enslave: in place of attacks, one creature within far DC 15 WIS or aboleth controls for 1d4 rounds. Telepathic: reads thoughts of all within far."
}

