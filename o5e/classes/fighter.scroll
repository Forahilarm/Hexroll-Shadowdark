FighterLevel10 (Fighter) {
    Level! = 10
    BaseStrength     @ 5d3+5
    BaseDexterity    @ 3d6
    BaseConstitution @ 4d3+5
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! @ 1d8+1d8+1d8+1d8+1d8+1d8+1d8+1d8+1d8
    Talent3! @ FighterTalent
