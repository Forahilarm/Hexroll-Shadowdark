        {%if exists("Talent6")%}; {{Talent6.Description}}{%endif%}
    %>

    | SDNPC
}

# ---------------------------------------------------------------------------
# FIGHTER LEVELS 1-10
# STR variant: high STR primary, CON secondary
# DEX variant: high DEX primary, CON secondary
# HP: 8 base + scaling dice + CON mod + Dwarf +2
# ---------------------------------------------------------------------------

FighterLevel1 (Fighter) {
    Level! = 1
    BaseStrength     @ 5d3+3
    BaseDexterity    @ 3d6
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! = 0
    | Fighter
}

FighterDEXLevel1 (FighterDEX) {
    Level! = 1
    BaseStrength     @ 3d6
    BaseDexterity    @ 5d3+3
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! = 0
    | FighterDEX
}

FighterLevel2 (Fighter) {
    Level! = 2
    BaseStrength     @ 5d3+3
    BaseDexterity    @ 3d6
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! @ 1d8
    | Fighter
}

FighterDEXLevel2 (FighterDEX) {
    Level! = 2
    BaseStrength     @ 3d6
    BaseDexterity    @ 5d3+3
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! @ 1d8
    | FighterDEX
}

FighterLevel3 (Fighter) {
    Level! = 3
    BaseStrength     @ 5d3+3
    BaseDexterity    @ 3d6
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! @ 1d8+1d8
    Talent3! @ FighterTalent
    | Fighter
}

FighterDEXLevel3 (FighterDEX) {
    Level! = 3
    BaseStrength     @ 3d6
    BaseDexterity    @ 5d3+3
    BaseConstitution @ 4d3+4
    BaseIntelligence @ 3d6
    BaseWisdom       @ 3d6
    BaseCharisma     @ 3d6
    HPDice! @ 1d8+1d8
    Talent3! @ FighterDEXTalent
    | FighterDEX
}

FighterLevel4 (Fighter) {
